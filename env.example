# Copy to `.env` and customize before running:
#   cp vars.example .env
#   docker compose up --build

# ---------------------------------------------------------------------------
# Paths (host directories — use absolute paths)
# ---------------------------------------------------------------------------

# Persistent MySQL data directory on the host
DATABASE_DATA_DIR=./data/mysql

# OpenWork agent workspace (project files, skills, opencode config)
OPENWORK_WORKSPACE=./workspace

# OpenWork host runtime data (OpenCode caches, server config, sidecars)
OPENWORK_DATA_DIR=./data/openwork

# Share service local blob storage
SHARE_BLOB_DIR=./data/share-blobs

# ---------------------------------------------------------------------------
# Database (MySQL)
# ---------------------------------------------------------------------------

MYSQL_ROOT_PASSWORD=openwork
MYSQL_DATABASE=openwork
MYSQL_USER=openwork
MYSQL_PASSWORD=openwork
MYSQL_PORT=3306

# Full connection URL (used by optional Den/cloud services)
DATABASE_URL=mysql://openwork:openwork@mysql:3306/openwork

# ---------------------------------------------------------------------------
# Ollama (external — containers reach your LAN host directly)
# ---------------------------------------------------------------------------

# URL reachable from inside Docker containers (not localhost on your Mac)
OLLAMA_BASE_URL=http://192.168.50.202:11434

# Model name as shown in `ollama list` on that host
OLLAMA_MODEL=gemma4-e4b-it-q4_K_M-98k

# 1 = wait for Ollama /api/tags before starting OpenWork
OPENWORK_WAIT_FOR_OLLAMA=1

# ---------------------------------------------------------------------------
# OpenWork host (orchestrator + opencode + openwork-server + opencode-router)
# ---------------------------------------------------------------------------

OPENWORK_ORCHESTRATOR_VERSION=0.13.12
OPENWORK_PORT=8787
OPENWORK_OPENCODE_PORT=4096
OPENWORK_OPENCODE_ROUTER_PORT=3005

# Browser-facing hostname/IP for connect URLs printed in logs
OPENWORK_PUBLIC_HOST=localhost

# Client and host auth tokens (auto-generated if left empty)
OPENWORK_TOKEN=
OPENWORK_HOST_TOKEN=

# auto | manual
OPENWORK_APPROVAL_MODE=auto

# CORS origins for the OpenWork server (* for local dev)
OPENWORK_CORS_ORIGINS=*

# 1 = write/update workspace/.config/opencode/opencode.json on every start
OPENCODE_CONFIG_FORCE=0

# 1 = enable opencode-router (multi-workspace JIT switching)
OPENWORK_ENABLE_OPENCODE_ROUTER=1

# Isolated OpenCode dev state (recommended for containerized local use)
OPENWORK_DEV_MODE=1
OPENWORK_DEV_ID=default

# ---------------------------------------------------------------------------
# OpenWork web UI
# ---------------------------------------------------------------------------

WEB_PORT=5173
OPENWORK_GIT_REF=dev
OPENWORK_REPO=https://github.com/different-ai/openwork.git

# ---------------------------------------------------------------------------
# Share service
# ---------------------------------------------------------------------------

SHARE_PORT=3006
PUBLIC_BASE_URL=http://localhost:3006
PUBLIC_OPENWORK_APP_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Compose
# ---------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=openwork
